<?php

namespace {{ namespace }};

use App\Models\Dog;

class {{ class }}
{
    public function handle(array $rows): void
    {
        foreach ($rows as $row) {
            $normalized = (new NormalizeDogsService())->handle($row);

            Dog::updateOrCreate(
                ['name' => $normalized['name']],
                $normalized
            );
        }
    }
}
